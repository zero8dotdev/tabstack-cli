{
  "name": "tabstack-cli",
  "version": "0.6.1",
  "description": "Gold-standard Bun CLI for the Tabstack AI web extraction, generation, research, and automation API",
  "type": "module",
  "bin": {
    "tabstack": "./src/index.ts"
